generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductType {
  ACCOUNT
  SOFTWARE
  EMAIL
  SERVICE
  OTHER
}

// New enums for listing system
enum ListingKind {
  PRODUCT
  SERVICE
}

enum ListingCategory {
  // Product categories
  EMAIL
  PRODUCT_SOFTWARE
  ACCOUNT
  PRODUCT_OTHER
  
  // Service categories
  ENGAGEMENT
  SERVICE_SOFTWARE
  BLOCKCHAIN
  SERVICE_OTHER
}

enum ProductSubType {
  // Email subtypes
  GMAIL
  HOTMAIL
  OUTLOOKMAIL
  IUUMAIL
  DOMAINMAIL
  YAHOOMAIL
  PROTONMAIL
  OTHER_MAIL
  
  // Software subtypes (extensible)
  WINDOWS_SOFTWARE
  MAC_SOFTWARE
  MOBILE_APP
  WEB_APP
  OTHER_SOFTWARE
  
  // Account subtypes (extensible)
  SOCIAL_ACCOUNT
  GAMING_ACCOUNT
  STREAMING_ACCOUNT
  OTHER_ACCOUNT
  
  // Service subtypes (extensible)
  FACEBOOK_ENGAGEMENT
  INSTAGRAM_ENGAGEMENT
  TIKTOK_ENGAGEMENT
  YOUTUBE_ENGAGEMENT
  OTHER_ENGAGEMENT
  
  BLOCKCHAIN_DEV
  SMART_CONTRACT
  NFT_SERVICE
  OTHER_BLOCKCHAIN
  
  CUSTOM_SOFTWARE_DEV
  API_INTEGRATION
  OTHER_SERVICE_SOFTWARE
  
  GENERAL_OTHER
}

enum ConversationType {
  DIRECT
  SUPPORT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique @db.VarChar(20)
  passwordHash  String?
  googleId      String?   @unique
  fullName      String?
  phone         String?
  balance       Decimal   @default(0) @db.Decimal(12, 2)
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  shop          Shop?
  orders        Order[]
  purchases     Purchase[]
  transactions  Transaction[]
  favorites     ProductFavorite[]
  conversationParticipants ConversationParticipant[]
  sentMessages  ChatMessage[] @relation("ChatMessageSender")
  
  @@index([email])
  @@index([username])
  @@index([googleId])
}

model Shop {
  id            String    @id @default(cuid())
  userId        String    @unique
  name          String
  description   String?
  logo          String?
  isActive      Boolean   @default(true)
  rating        Float     @default(0)
  totalSales    Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      Product[]
  
  @@index([userId])
  @@index([isActive])
}

model Product {
  id            String      @id @default(cuid())
  shopId        String
  name          String
  description   String
  type          ProductType // Keep for backward compatibility
  
  // New listing system fields
  slug          String?     @unique
  kind          ListingKind?
  category      ListingCategory?
  subType       ProductSubType?
  shortDescription String?
  badgeText     String?
  
  // Pricing (keep old price for backward compatibility)
  price         Float
  
  // Stats and metrics
  stock         Int         @default(0)
  sold          Int         @default(0)
  ratingAvg     Decimal?    @db.Decimal(3, 2)
  reviewCount   Int         @default(0)
  completedOrders Int       @default(0)
  complaintPercent Decimal  @default(0) @db.Decimal(5, 2)
  
  images        String[]
  isActive      Boolean     @default(true)
  autoDeliver   Boolean     @default(false)

  // Private warehouse (external API inventory)
  usePrivateWarehouse Boolean  @default(false)
  warehouseApiUrl     String?
  warehouseApiKey     String?

  // Metadata for different product types
  metadata      Json?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  purchases     Purchase[]
  inventory     Inventory[]
  features      ProductFeature[]
  priceOptions  ProductPriceOption[]
  favorites     ProductFavorite[]
  
  @@index([shopId])
  @@index([type])
  @@index([isActive])
  @@index([kind, category, subType])
  @@index([slug])
}

model Inventory {
  id            String    @id @default(cuid())
  productId     String
  data          String    // Account credentials, license key, etc.
  isSold        Boolean   @default(false)
  soldAt        DateTime?
  
  createdAt     DateTime  @default(now())
  
  // Relations
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId, isSold])
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  orderNumber   String        @unique
  totalAmount   Decimal       @db.Decimal(12, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  user          User          @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payment       Payment?
  
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  price         Decimal   @db.Decimal(12, 2)
  deliveredData String?   // Data delivered to customer
  
  createdAt     DateTime  @default(now())
  
  // Relations
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  method        String        // BANK_TRANSFER, MOMO, ZALOPAY, etc.
  status        PaymentStatus @default(PENDING)
  transactionId String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([status])
}

model Purchase {
  id            String    @id @default(cuid())
  userId        String
  productId     String
  orderId       String?
  status        OrderStatus
  
  createdAt     DateTime  @default(now())
  
  // Relations
  user          User      @relation(fields: [userId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  
  // Prevent duplicate purchases
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Transaction {
  id            String    @id @default(cuid())
  userId        String
  amount        Decimal   @db.Decimal(12, 2)
  type          String    // DEPOSIT, WITHDRAW, PURCHASE, REFUND
  description   String?
  balanceBefore Decimal   @db.Decimal(12, 2)
  balanceAfter  Decimal   @db.Decimal(12, 2)
  
  createdAt     DateTime  @default(now())
  
  // Relations
  user          User      @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([type])
}

// New tables for listing system

model ProductFeature {
  id          String   @id @default(cuid())
  productId   String
  content     String
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  // Relations
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
}

model ProductPriceOption {
  id          String   @id @default(cuid())
  productId   String
  label       String
  price       Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId, isActive])
}

model ProductFavorite {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Conversation {
  id            String                    @id @default(cuid())
  type          ConversationType          @default(DIRECT)
  title         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  participants  ConversationParticipant[]
  messages      ChatMessage[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id              String        @id @default(cuid())
  conversationId  String
  userId          String
  lastReadAt      DateTime?
  createdAt       DateTime      @default(now())

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model ChatMessage {
  id              String        @id @default(cuid())
  conversationId  String
  senderId        String
  content         String
  createdAt       DateTime      @default(now())

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}
