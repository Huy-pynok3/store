# Production Environment Variables for Backend API
# Copy this to backend/.env and update with your production values

# Database - Use your EC2 PostgreSQL
DATABASE_URL="postgresql://marketplace_user:your_secure_password_here@localhost:5432/marketplace?schema=public"

# Redis - Local Redis on EC2
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT - Generate a strong secret key with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=production

# Frontend URL - Your Vercel domain
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ENABLED=true

# Google OAuth - Update callback URL to your API domain
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=https://api.your-domain.com/api/auth/google/callback
