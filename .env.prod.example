# Production Environment Variables
# Copy to .env.prod and update with your production values

NODE_ENV=production

# Database
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=marketplace
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Backend
BACKEND_PORT=3001
JWT_SECRET=your_jwt_secret_generate_with_openssl
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_PORT=3000
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=https://api.your-domain.com/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ENABLED=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
NEXT_PUBLIC_TURNSTILE_ENABLED=true

# Docker build settings
DOCKERFILE=Dockerfile
BUILD_TARGET=production
BACKEND_CMD=node dist/main
FRONTEND_CMD=npm start
